# =========================================
# IMMO PRO-X — Client-side env variables
# Copy this file to .env and fill the values.
# Only VITE_* vars are exposed to the browser.
# =========================================

# --- Required ---
# Supabase project URL (Dashboard > Settings > API > Project URL)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon key (Dashboard > Settings > API > anon public)
# Public by design — security comes from Postgres RLS policies.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...


# =========================================
# Server-side secrets (DO NOT PUT HERE)
# Configure via: Supabase Dashboard > Edge Functions > Secrets
# Or CLI: supabase secrets set KEY=value
# =========================================
#
# ANTHROPIC_API_KEY         — AI call scripts, suggestions (Claude)
# OPENAI_API_KEY            — Optional fallback
# RESEND_API_KEY            — Transactional emails + campaigns
# WHATSAPP_TOKEN            — Meta WhatsApp Cloud API (if used)
# WHATSAPP_PHONE_NUMBER_ID  — Meta sender phone ID
#
# Postgres settings (Dashboard > Database > Settings > Custom Postgres Config)
# — required for pg_cron to call edge functions
#
# app.settings.supabase_url        = https://<project-ref>.supabase.co
# app.settings.service_role_key    = eyJ... (service role — NEVER commit)
